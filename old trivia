<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ultimate Marvel Trivia Quest</title>
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Roboto:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --marvel-red: #e62429;
            --marvel-dark-red: #9f1115;
            --marvel-gold: #fbc02d;
            --marvel-dark: #151515;
            --marvel-grey: #202020;
            --marvel-light-grey: #333333;
            --marvel-white: #f0f0f0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: var(--marvel-dark);
            color: var(--marvel-white);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background-image: 
                radial-gradient(circle at 50% 20%, rgba(230, 36, 41, 0.15) 0%, transparent 60%),
                radial-gradient(circle at 80% 80%, rgba(251, 192, 45, 0.08) 0%, transparent 50%);
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 650px;
            background: var(--marvel-grey);
            border: 3px solid var(--marvel-red);
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(230, 36, 41, 0.3), 0 0 20px rgba(0, 0, 0, 0.8);
            overflow: hidden;
            position: relative;
        }

        header {
            background-color: var(--marvel-red);
            padding: 20px;
            text-align: center;
            border-bottom: 4px solid var(--marvel-gold);
            position: relative;
        }

        h1 {
            font-family: 'Bangers', cursive;
            font-size: 3rem;
            letter-spacing: 2px;
            color: #fff;
            text-shadow: 3px 3px 0px #000;
            text-transform: uppercase;
        }

        .subtitle {
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            color: var(--marvel-gold);
            text-transform: uppercase;
            margin-top: 5px;
        }

        .card-body {
            padding: 25px;
        }

        /* Screen States */
        .screen {
            display: none;
        }

        .screen.active {
            display: block;
        }

        /* Welcome Screen */
        .welcome-screen {
            text-align: center;
        }

        .welcome-screen p {
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 25px;
            color: #ccc;
        }

        .btn {
            background: var(--marvel-red);
            color: white;
            font-family: 'Bangers', cursive;
            font-size: 1.5rem;
            letter-spacing: 1px;
            padding: 12px 30px;
            border: 2px solid var(--marvel-gold);
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 0 var(--marvel-dark-red);
            text-transform: uppercase;
            display: inline-block;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 0 var(--marvel-dark-red);
            background: #ff2a30;
        }

        .btn:active {
            transform: translateY(2px);
            box-shadow: 0 2px 0 var(--marvel-dark-red);
        }

        /* Quiz Screen */
        .quiz-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            font-weight: bold;
            font-size: 0.95rem;
            color: #aaa;
            border-bottom: 1px solid var(--marvel-light-grey);
            padding-bottom: 10px;
        }

        .score-tracker {
            color: var(--marvel-gold);
        }

        .progress-bar-container {
            width: 100%;
            height: 8px;
            background-color: var(--marvel-light-grey);
            border-radius: 4px;
            margin-bottom: 25px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background-color: var(--marvel-gold);
            transition: width 0.3s ease;
        }

        .question-text {
            font-size: 1.3rem;
            font-weight: 700;
            line-height: 1.4;
            margin-bottom: 25px;
            color: #fff;
        }

        .options-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .option-btn {
            background: var(--marvel-light-grey);
            border: 2px solid #444;
            color: #fff;
            padding: 14px 18px;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 500;
            text-align: left;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .option-btn:hover:not([disabled]) {
            border-color: var(--marvel-gold);
            background: #3d3d3d;
            transform: translateX(4px);
        }

        .option-btn.correct {
            background-color: #2e7d32 !important;
            border-color: #4caf50 !important;
            color: #fff;
        }

        .option-btn.incorrect {
            background-color: #c62828 !important;
            border-color: #ef5350 !important;
            color: #fff;
        }

        .next-btn-container {
            margin-top: 25px;
            text-align: right;
        }

        /* Result Screen */
        .result-screen {
            text-align: center;
        }

        .result-score {
            font-family: 'Bangers', cursive;
            font-size: 4rem;
            color: var(--marvel-gold);
            margin: 15px 0;
            text-shadow: 2px 2px 0 #000;
        }

        .result-title {
            font-size: 1.8rem;
            font-weight: 900;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .result-msg {
            color: #ccc;
            margin-bottom: 30px;
            font-size: 1.1rem;
            line-height: 1.5;
        }

        /* Footer */
        footer {
            margin-top: 20px;
            font-size: 0.8rem;
            color: #777;
            text-align: center;
        }

        @media (max-width: 480px) {
            h1 { font-size: 2.2rem; }
            .question-text { font-size: 1.1rem; }
            .option-btn { font-size: 0.95rem; padding: 12px; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>MARVEL TRIVIA</h1>
            <div class="subtitle">Test Your MCU & Comic Knowledge</div>
        </header>

        <div class="card-body">
            <!-- Welcome Screen -->
            <div id="welcome-screen" class="screen active welcome-screen">
                <p>Are you worthy of holding the Mjolnir of Marvel knowledge? Test your skills with 10 randomly selected Marvel trivia questions!</p>
                <button id="start-btn" class="btn">Assemble & Start</button>
            </div>

            <!-- Quiz Screen -->
            <div id="quiz-screen" class="screen">
                <div class="quiz-header">
                    <span id="question-count">Question 1/10</span>
                    <span class="score-tracker">Score: <span id="current-score">0</span></span>
                </div>
                <div class="progress-bar-container">
                    <div id="progress-bar" class="progress-bar"></div>
                </div>

                <div id="question-text" class="question-text">Loading question...</div>
                <div id="options-container" class="options-container">
                    <!-- Dynamic option buttons go here -->
                </div>

                <div class="next-btn-container">
                    <button id="next-btn" class="btn" style="display: none;">Next Question</button>
                </div>
            </div>

            <!-- Result Screen -->
            <div id="result-screen" class="screen result-screen">
                <div id="result-title" class="result-title">AVENGERS ASSEMBLE!</div>
                <div id="result-score" class="result-score">8 / 10</div>
                <div id="result-msg" class="result-msg">You know your stuff! You'd fit right in with the Guardians of the Galaxy.</div>
                <button id="restart-btn" class="btn">Play Again</button>
            </div>
        </div>
    </div>

    <footer>
        Marvel Trivia Quiz &bull; Created for True Believers
    </footer>

    <script>
        // Marvel Questions Database
        const questionBank = [
            {
                question: "What is the real name of Black Panther?",
                options: ["T'Challa", "M'Baku", "N'Jadaka", "W'Kabi"],
                answer: 0
            },
            {
                question: "What metal is Captain America's shield made of?",
                options: ["Adamantium", "Vibranium", "Uru", "Promethium"],
                answer: 1
            },
            {
                question: "What color is the Power Stone in the MCU?",
                options: ["Blue", "Red", "Purple", "Green"],
                answer: 2
            },
            {
                question: "Who destroyed Thor's hammer Mjolnir in 'Thor: Ragnarok'?",
                options: ["Thanos", "Loki", "Odin", "Hela"],
                answer: 3
            },
            {
                question: "What alien species does Carol Danvers gain her powers from/fight beside in Captain Marvel?",
                options: ["Skrulls", "Kree", "Chitauri", "Sovereign"],
                answer: 1
            },
            {
                question: "What is the name of Tony Stark's AI assistant that replaces J.A.R.V.I.S.?",
                options: ["F.R.I.D.A.Y.", "K.A.R.E.N.", "E.D.I.T.H.", "H.O.M.E.R."],
                answer: 0
            },
            {
                question: "In which fictional African nation is Black Panther set?",
                options: ["Genosha", "Sokovia", "Wakanda", "Madripoor"],
                answer: 2
            },
            {
                question: "What is Doctor Strange's primary relic that holds the Time Stone?",
                options: ["Cloak of Levitation", "Eye of Agamotto", "Orb of Agamotto", "Book of Cagliostro"],
                answer: 1
            },
            {
                question: "Which weapon does Thor forge in 'Avengers: Infinity War'?",
                options: ["Mjolnir", "Jarnbjorn", "Thunderstrike", "Stormbreaker"],
                answer: 3
            },
            {
                question: "Who was responsible for creating the Avengers Initiative?",
                options: ["Tony Stark", "Nick Fury", "Alexander Pierce", "Phil Coulson"],
                answer: 1
            },
            {
                question: "What is Peter Parker's best friend's name in the MCU Spider-Man trilogy?",
                options: ["Harry Osborn", "Ned Leeds", "Flash Thompson", "Miles Morales"],
                answer: 1
            },
            {
                question: "What realm is Loki from by birth?",
                options: ["Asgard", "Jotunheim", "Vanaheim", "Nidavellir"],
                answer: 1
            },
            {
                question: "What species is Rocket from Guardians of the Galaxy?",
                options: ["Genetically modified raccoon", "Badger", "Red Panda", "Swarley"],
                answer: 0
            },
            {
                question: "What is the name of the cosmic cube that houses the Space Stone?",
                options: ["Aether", "Tesseract", "Orb", "Scepter"],
                answer: 1
            },
            {
                question: "Who is Scott Lang's primary mentor in Ant-Man?",
                options: ["Hank Pym", "Howard Stark", "Bruce Banner", "Darren Cross"],
                answer: 0
            },
            {
                question: "What is the name of Natasha Romanoff's sister in Black Widow?",
                options: ["Melina Vostokoff", "Yelena Belova", "Wanda Maximoff", "Maria Hill"],
                answer: 1
            },
            {
                question: "Which infinity stone was contained inside the Loki's Scepter?",
                options: ["Mind Stone", "Space Stone", "Reality Stone", "Power Stone"],
                answer: 0
            },
            {
                question: "Where did Thanos acquire the Soul Stone?",
                options: ["Xandar", "Titan", "Vormir", "Knowhere"],
                answer: 2
            },
            {
                question: "What song does Peter Quill dance to in the opening scene of Guardians of the Galaxy?",
                options: ["Hooked on a Feeling", "Come and Get Your Love", "Cherry Bomb", "Mr. Blue Sky"],
                answer: 1
            },
            {
                question: "What metal is fused to Wolverine's skeleton?",
                options: ["Vibranium", "Promethium", "Adamantium", "Carbonantium"],
                answer: 2
            }
        ];

        const TOTAL_QUESTIONS = 10;
        let selectedQuestions = [];
        let currentQuestionIndex = 0;
        let score = 0;
        let selectedOption = null;

        // DOM Elements
        const welcomeScreen = document.getElementById('welcome-screen');
        const quizScreen = document.getElementById('quiz-screen');
        const resultScreen = document.getElementById('result-screen');

        const startBtn = document.getElementById('start-btn');
        const nextBtn = document.getElementById('next-btn');
        const restartBtn = document.getElementById('restart-btn');

        const questionCountText = document.getElementById('question-count');
        const currentScoreText = document.getElementById('current-score');
        const progressBar = document.getElementById('progress-bar');
        const questionText = document.getElementById('question-text');
        const optionsContainer = document.getElementById('options-container');

        const resultTitle = document.getElementById('result-title');
        const resultScore = document.getElementById('result-score');
        const resultMsg = document.getElementById('result-msg');

        // Event Listeners
        startBtn.addEventListener('click', startQuiz);
        nextBtn.addEventListener('click', handleNextQuestion);
        restartBtn.addEventListener('click', startQuiz);

        // Helper function to shuffle an array (Fisher-Yates Shuffle)
        function shuffleArray(array) {
            const arr = [...array];
            for (let i = arr.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [arr[i], arr[j]] = [arr[j], arr[i]];
            }
            return arr;
        }

        // Start / Reset Quiz
        function startQuiz() {
            score = 0;
            currentQuestionIndex = 0;
            currentScoreText.textContent = score;

            // Randomly select and randomize questions
            const shuffledBank = shuffleArray(questionBank);
            selectedQuestions = shuffledBank.slice(0, TOTAL_QUESTIONS).map(q => {
                // Shuffle options for each selected question while keeping track of the correct answer
                const originalOptions = [...q.options];
                const correctAnswerText = originalOptions[q.answer];
                const shuffledOptions = shuffleArray(originalOptions);
                const newAnswerIndex = shuffledOptions.indexOf(correctAnswerText);

                return {
                    question: q.question,
                    options: shuffledOptions,
                    answer: newAnswerIndex
                };
            });

            // Switch screen
            welcomeScreen.classList.remove('active');
            resultScreen.classList.remove('active');
            quizScreen.classList.add('active');

            loadQuestion();
        }

        // Load Question UI
        function loadQuestion() {
            nextBtn.style.display = 'none';
            selectedOption = null;

            const q = selectedQuestions[currentQuestionIndex];

            // Update Progress
            questionCountText.textContent = `Question ${currentQuestionIndex + 1}/${TOTAL_QUESTIONS}`;
            progressBar.style.width = `${((currentQuestionIndex) / TOTAL_QUESTIONS) * 100}%`;

            // Set Question Text
            questionText.textContent = q.question;

            // Clear & Populate Options
            optionsContainer.innerHTML = '';
            q.options.forEach((optIndexText, index) => {
                const btn = document.createElement('button');
                btn.classList.add('option-btn');
                btn.textContent = optIndexText;
                btn.addEventListener('click', () => selectOption(btn, index));
                optionsContainer.appendChild(btn);
            });
        }

        // Option Selection Handler
        function selectOption(btnElement, index) {
            if (selectedOption !== null) return; // Prevent multiple clicks

            selectedOption = index;
            const q = selectedQuestions[currentQuestionIndex];
            const allOptionBtns = optionsContainer.querySelectorAll('.option-btn');

            // Disable all options
            allOptionBtns.forEach(b => b.setAttribute('disabled', 'true'));

            if (index === q.answer) {
                btnElement.classList.add('correct');
                score++;
                currentScoreText.textContent = score;
            } else {
                btnElement.classList.add('incorrect');
                // Highlight correct option
                allOptionBtns[q.answer].classList.add('correct');
            }

            nextBtn.style.display = 'inline-block';
        }

        // Next Question or Finish
        function handleNextQuestion() {
            currentQuestionIndex++;

            if (currentQuestionIndex < TOTAL_QUESTIONS) {
                loadQuestion();
            } else {
                showResults();
            }
        }

        // Show Results Screen
        function showResults() {
            quizScreen.classList.remove('active');
            resultScreen.classList.add('active');

            resultScore.textContent = `${score} / ${TOTAL_QUESTIONS}`;

            if (score === 10) {
                resultTitle.textContent = "SUPREME MARVEL MASTER!";
                resultMsg.textContent = "Excelsior! You answered every question correctly. Even the Ancient One would be impressed!";
            } else if (score >= 7) {
                resultTitle.textContent = "AVENGER MATERIAL!";
                resultMsg.textContent = "Great job! You definitely know your way around the Marvel Universe.";
            } else if (score >= 4) {
                resultTitle.textContent = "AGENT OF S.H.I.E.L.D.";
                resultMsg.textContent = "Not bad, but you might need a rewatch of Phase 1 through 4 to level up!";
            } else {
                resultTitle.textContent = "NOOBMASTER69 LEVEL";
                resultMsg.textContent = "Looks like Thor snapped you away! Time for a Marvel movie marathon before trying again.";
            }
        }
    </script>
</body>
</html>
